---
import Layout from '../../layouts/Layout.astro';
import Cursor from '../../components/Cursor';
import Nav from '../../components/Nav';
import Footer from '../../components/Footer';
import AnimatedText from '../../components/AnimatedText';
import MagneticButton from '../../components/MagneticButton';
import MarqueeSection from '../../components/MarqueeSection';

export function getStaticPaths() {
  const cases = [
    {
      slug: '01',
      title: 'A Framing Company',
      category: 'Web Design + WordPress',
      year: '2024',
      client: 'A Framing Company',
      industry: 'Construction',
      services: ['Web Design', 'WordPress Development'],
      duration: '6 weeks',
      liveUrl: 'https://aframingcompany.com',
      image: '/images/work-aframing.jpg',
      challenge: 'A Framing Company is a Utah-based framing contractor with a strong reputation for precision craftsmanship — wood framing, concrete work, and roofing across residential and commercial builds. But their online presence didn\'t reflect their calibre. An outdated site with no portfolio presence meant they were losing bids to competitors who simply looked more credible online.',
      solution: 'We designed a clean, high-performance WordPress website that put their project portfolio front and centre. The structure was built around three core audiences — general contractors, developers, and homeowners — with clear service pages for wood framing, concrete, and roofing. A curated project gallery highlighted completed builds across Utah, and testimonials from past clients were woven throughout to reinforce trust. The WordPress build gives the team full control to update projects and content without touching code.',
      result: 'Within weeks of launch, A Framing Company reported a significant uptick in inbound enquiries from contractors and developers who found them through search or were sent the site during the bidding process. The site became a core part of how they pitch new work.',
      outcomes: ['Stronger inbound lead volume from contractors & developers', 'Professional portfolio presence supporting bid process', 'Mobile-first design serving field-based clients', 'Client-editable WordPress CMS for easy content updates'],
    },
    {
      slug: '02',
      title: 'Cleen & Green',
      category: 'Brand Identity + WordPress',
      year: '2025',
      client: 'Cleen & Green',
      industry: 'Cleaning Services',
      services: ['Brand Identity', 'Web Design', 'WordPress Development'],
      duration: '8 weeks',
      liveUrl: 'https://cleenandgreen.com',
      image: '/images/work-cleen.jpg',
      challenge: 'Cleen & Green is a premium cleaning company based in the Philippines offering deep house cleaning, post-construction cleaning, car interior detailing, and eco-safe disinfection. Their ambition was to position above the typical cleaning service — but their existing brand identity and website didn\'t communicate the premium, eco-conscious experience they actually delivered. They were underselling themselves in a market where trust and first impressions are everything.',
      solution: 'We developed a full brand identity rooted in their eco-conscious values — a fresh green palette, clean typographic system, and a visual language built around clarity and care. The WordPress site was structured to convert: service pages with clear scope descriptions, a frictionless quote request flow, and customer testimonials at key decision points. We also built the franchise opportunity section as a dedicated page, giving it the professional weight it needed to attract serious enquiries — all manageable by the client through WordPress.',
      result: 'The rebrand gave Cleen & Green the market positioning that matched their actual service quality. The new site converts better, the brand is consistent across all touchpoints, and the franchise enquiry section opened a new growth channel they hadn\'t been able to activate before.',
      outcomes: ['Brand identity aligned with premium eco-positioning', 'Improved quote request conversion rate', 'Franchise section activated as a new revenue stream', 'Client-editable WordPress CMS across all service pages'],
    },
    {
      slug: '03',
      title: 'CrateOnScene',
      category: 'MVP Platform Build',
      year: '2024',
      client: 'CrateOnScene / Import Crate',
      industry: 'Automotive Events & Community',
      services: ['Web Design', 'Platform Development', 'PWA'],
      duration: '5 weeks',
      liveUrl: 'https://crateonscene.com',
      image: '/images/work-crate.jpg',
      challenge: 'CrateOnScene needed to go from idea to live product fast. The vision was a centralised automotive event discovery platform — a hub where drivers, spectators, businesses, and event organisers could find and connect around car shows, meets, and racing events across the US. They needed an MVP that felt polished enough to attract real users from day one, not a rough prototype.',
      solution: 'We scoped the MVP tightly: event discovery, driver profiles, business listings, and organiser tools — all built as a progressive web app so users could add it to their home screen without an app store. The UI was designed around the car culture aesthetic — dark, bold, high-contrast — with a clean information architecture that made browsing events by type, date, and location intuitive. We shipped in 5 weeks.',
      result: 'CrateOnScene launched with a fully functional platform serving multiple user types simultaneously. The PWA approach kept the barrier to entry low, and the event-first design kept users engaged from their first visit.',
      outcomes: ['Full MVP shipped in 5 weeks', 'Multi-stakeholder platform: drivers, organisers, businesses, spectators', 'PWA — installable without an app store', 'Event discovery across JDM, tuner, muscle, and import segments'],
    },
    {
      slug: '05',
      title: 'Canwell',
      category: 'Web Platform + Admin Portal',
      year: '2024',
      client: 'Canwell',
      industry: 'Health & Wellness',
      services: ['Web Design', 'Web Development', 'Admin Portal'],
      duration: '8 weeks',
      liveUrl: 'https://canwell.com.au',
      image: '/images/work-canwell.jpg',
      challenge: 'Canwell is an Australian health and wellness platform with a mission to help people take ownership of their health journey. They needed both a compelling public-facing website to communicate their offering and a robust admin portal for managing their growing user base, practitioners, and content — all under one cohesive digital system.',
      solution: 'We designed and built the full Canwell web platform: a clean, conversion-optimised public site built around the "Own Your Health" positioning, and a separate admin portal at admin.canwell.com.au for internal operations. The public site was structured to guide users through the platform\'s service categories with clear calls to action, while the admin portal gave the Canwell team full visibility and control over users, practitioners, and platform data.',
      result: 'Canwell launched with a polished digital presence that matched the ambition of their platform. The admin portal eliminated manual processes and gave the operations team the tools they needed to scale, while the public site built credibility and drove sign-ups from day one.',
      outcomes: ['Public website + dedicated admin portal delivered together', 'Clear "Own Your Health" narrative driving user acquisition', 'Admin portal streamlining operations for practitioners & users', 'Scalable platform architecture supporting future feature growth'],
    },
    {
      slug: '06',
      title: '8Drive',
      category: 'Web App — Car Rental System',
      year: '2024',
      client: '8Drive Cars',
      industry: 'Automotive — Car Rental',
      services: ['Web App Development', 'Booking System', 'Fleet Management'],
      duration: '10 weeks',
      liveUrl: 'https://intra2.8drivecars.com/',
      image: '/images/work-8drive.jpg',
      challenge: '8Drive Cars offers premium self-drive and chauffeured rentals across their fleet. Their existing booking and fleet management processes were largely manual — no centralised system to handle reservations, fleet availability, customer records, or chauffeur scheduling. They needed a purpose-built platform that could professionalise operations end-to-end.',
      solution: 'We built the 8Drive intranet system — a comprehensive web application handling the full rental workflow: fleet management with real-time availability, booking and reservation management, customer records, chauffeur assignment, and operational reporting. The UI was built around their premium brand aesthetic — dark navy, clean typography — with workflows designed for speed and clarity by staff processing bookings daily.',
      result: '8Drive moved from fragmented manual processes to a single system handling their entire operation. Booking times dropped significantly, fleet visibility improved across the board, and the team had clear operational data for the first time.',
      outcomes: ['Full car rental management system — bookings, fleet, customers, chauffeurs', 'Real-time fleet availability replacing manual tracking', 'Premium dark UI aligned with brand positioning', 'Operational reporting giving management clear visibility'],
    },
    {
      slug: '07',
      title: 'UGLQ',
      category: 'Membership Management Portal',
      year: '2024',
      client: 'United Grand Lodge of Queensland',
      industry: 'Non-profit — Fraternal Organisation',
      services: ['Web App Development', 'Membership Portal', 'System Integration'],
      duration: '12 weeks',
      liveUrl: 'https://connect.uglq.org.au/',
      image: '/images/work-uglq.jpg',
      challenge: 'The United Grand Lodge of Queensland (UGLQ) is the governing body for Freemasonry in Queensland, overseeing hundreds of lodges and thousands of members across the state. Their membership records, communications, and lodge administration were managed through disconnected legacy systems — creating inefficiencies for both the Grand Lodge and individual lodge secretaries.',
      solution: 'We built the UGLQ Connect portal — a secure, role-based membership management system for the Grand Lodge of Queensland. The platform handles member records, lodge administration, dues tracking, communications, and reporting across the entire Queensland Freemason network. Access is controlled by role (Grand Lodge administrators, lodge secretaries, members) with each level seeing only what\'s relevant to them. The gold and navy design reflects the organisation\'s heritage and gravitas.',
      result: 'UGLQ Connect became the operational backbone of Queensland Freemasonry — replacing a patchwork of legacy tools with one secure, purpose-built platform. Lodge secretaries reported significant time savings in administration, and the Grand Lodge gained the data visibility needed to manage the network effectively.',
      outcomes: ['Unified membership management across all Queensland lodges', 'Role-based access for Grand Lodge, lodge secretaries, and members', 'Dues tracking and financial reporting across the network', 'Secure, heritage-aligned design appropriate for the institution'],
    },
    {
      slug: '08',
      title: 'QLD Law Group',
      category: 'Website, Web App + Mobile App',
      year: '2025',
      client: 'QLD Law Group',
      industry: 'Legal Services',
      services: ['Web Design', 'Web App Development', 'Mobile App', 'Client Portal'],
      duration: '14 weeks',
      liveUrl: 'https://qldlawgroup.com.au/app/',
      image: '/images/work-qldlaw.jpg',
      challenge: 'QLD Law Group is a Queensland-based law firm serving both individual and corporate clients across multiple practice areas. They needed a complete digital overhaul — a professional public-facing website, a secure client portal for matter updates and document sharing, and a mobile app giving clients on-the-go access to their legal matters. Three interconnected products, one cohesive experience.',
      solution: 'We delivered the full QLD Law Group digital suite: a conversion-focused website communicating the firm\'s expertise and practice areas, a web app client portal where clients can track matter progress, upload documents, and communicate with their lawyer, and a mobile app extending the same portal experience to iOS and Android. The system was designed around the client experience — clear, secure, and accessible — with the firm\'s red and professional palette carrying through every touchpoint.',
      result: 'QLD Law Group launched with a complete digital presence that set them apart from competitors still relying on phone and email alone. Client satisfaction improved as matters became more transparent, document turnaround accelerated, and the firm was able to take on more clients without adding administrative overhead.',
      outcomes: ['Full digital suite: website + web app + mobile app delivered together', 'Secure client portal for matter tracking and document exchange', 'Mobile app on iOS and Android extending portal access', 'Reduced admin overhead — clients self-serve document uploads and status checks'],
    },
    {
      slug: '04',
      title: 'The Telecom Shop',
      category: 'E-commerce Migration',
      year: '2024',
      client: 'The Telecom Shop',
      industry: 'Retail — Telecommunications',
      services: ['E-commerce Migration', 'PrestaShop Development', 'Data Migration'],
      duration: '10 weeks',
      liveUrl: 'https://www.thetelecomshop.com/au/',
      image: '/images/work-telecom.jpg',
      challenge: "The Telecom Shop is an Australian retailer selling phones, tablets, accessories, and plans online. Their Magento store had become a liability — slow, expensive to maintain, and increasingly difficult to update. They needed to migrate their full catalogue, customer data, and order history to PrestaShop without disrupting sales or losing SEO ground during the transition.",
      solution: 'We planned the migration in phases: data audit and mapping first, then a parallel PrestaShop build matching their existing catalogue structure, followed by a staged migration of products, customers, and orders. The new PrestaShop store was redesigned to be faster and easier to manage — cleaner product pages, streamlined checkout, and a backend the team could actually use without developer help. Go-live was sequenced to minimise downtime.',
      result: 'The migration completed with zero data loss and minimal disruption to trading. The new PrestaShop store loaded significantly faster than the old Magento build, and the team regained full control of their catalogue and promotions without needing ongoing developer involvement.',
      outcomes: ['Full Magento-to-PrestaShop migration with zero data loss', 'Faster storefront — significant improvement in page load times', 'Clean product, customer, and order history transfer', 'Team-managed backend requiring no developer for day-to-day operations'],
    },
  ];

  return cases.map(c => ({ params: { slug: c.slug }, props: c }));
}

const { title, category, year, client, industry, services, duration, challenge, solution, result, outcomes, slug, image, liveUrl } = Astro.props;
---

<Layout
  title={`${title} — Case Study | Fazed Digital`}
  description={`How Fazed Digital helped ${client} with ${category}. See the challenge, our approach, and the results.`}
  page="work"
  schema={[
    {
      "@context": "https://schema.org",
      "@type": "CreativeWork",
      "name": `${title} — Case Study`,
      "description": `Fazed Digital case study: ${category} for ${client} in the ${industry} industry.`,
      "url": `https://fazeddigital.com/work/${slug}`,
      "creator": { "@type": "Organization", "name": "Fazed Digital", "url": "https://fazeddigital.com" },
      "dateCreated": year,
      "genre": category,
      "keywords": services.join(", ")
    },
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fazeddigital.com" },
        { "@type": "ListItem", "position": 2, "name": "Work", "item": "https://fazeddigital.com/work" },
        { "@type": "ListItem", "position": 3, "name": title, "item": `https://fazeddigital.com/work/${slug}` }
      ]
    }
  ]}
>
  <Cursor client:only="react" />
  <Nav client:only="react" currentPath="/work" />

  <main>
    <!-- Hero -->
    <section style="padding-top: 9rem; padding-bottom: clamp(3rem,6vw,5rem); background: var(--black); border-bottom: 1px solid var(--border);">
      <div class="container">
        <div style="display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 2rem;">
          <a href="/work" style="display: inline-flex; align-items: center; gap: 0.5rem; color: var(--gray-500); font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.1em; text-transform: uppercase; transition: color 0.2s;"
            onmouseover="this.style.color='var(--white)'" onmouseout="this.style.color='var(--gray-500)'">
            ← Back to Work
          </a>
          <a href={liveUrl} target="_blank" rel="noopener noreferrer"
            style="display: inline-flex; align-items: center; gap: 0.5rem; font-family: var(--font-mono); font-size: 0.68rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); border: 1px solid var(--accent-border); border-radius: 100px; padding: 0.45rem 1.1rem; transition: all 0.2s; text-decoration: none;"
            onmouseover="this.style.background='var(--accent-muted)'; this.style.borderColor='var(--accent)';" onmouseout="this.style.background='transparent'; this.style.borderColor='var(--accent-border)';">
            <span style="display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--accent);"></span>
            Visit Live Site ↗
          </a>
        </div>
        <div style="display: flex; gap: 1rem; align-items: center; margin-bottom: 2rem; flex-wrap: wrap;">
          <span class="label">{category}</span>
          <span class="label">—</span>
          <span class="label">{year}</span>
        </div>
        <AnimatedText
          client:only="react"
          text={title}
          as="h1"
          className="display-lg"
          style={{ marginBottom: '3rem' }}
        />
        <!-- Meta row -->
        <div class="work-meta-grid" style="display: grid; grid-template-columns: repeat(4,1fr); gap: 2rem; padding: 2rem 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
          {[
            { label: 'Client',    value: client },
            { label: 'Industry',  value: industry },
            { label: 'Services',  value: services.join(', ') },
            { label: 'Duration',  value: duration },
          ].map(m => (
            <div>
              <div class="label" style="margin-bottom: 0.35rem;">{m.label}</div>
              <div style="font-size: 0.9rem; color: var(--gray-200);">{m.value}</div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Visual placeholder -->
    <section style="background: var(--gray-900); border-bottom: 1px solid var(--border); overflow: hidden;">
      <div class="container" style="padding-top: clamp(3rem,6vw,6rem); padding-bottom: clamp(3rem,6vw,6rem);">
        <div style="aspect-ratio: 16/7; border-radius: var(--radius); border: 1px solid var(--border); overflow: hidden; position: relative; background: var(--gray-900);">
          <img
            src={image}
            alt={`${title} website`}
            loading="eager"
            decoding="async"
            width={1200}
            height={750}
            style="width: 100%; height: 100%; object-fit: cover; object-position: top center; display: block;"
          />
        </div>
      </div>
    </section>

    <!-- Case study content -->
    <section class="section" style="background: var(--black);">
      <div class="container">
        <div class="work-content-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: clamp(3rem,6vw,8rem);">
          {[
            { label: 'The Challenge', body: challenge },
            { label: 'Our Approach',  body: solution },
          ].map(({ label, body }) => (
            <div>
              <div class="label" style="margin-bottom: 1.5rem;">{label}</div>
              <p style="color: var(--gray-400); line-height: 1.8; font-size: 1.0125rem;">{body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Results -->
    <section style="padding: clamp(4rem,8vw,8rem) 0; background: var(--gray-900); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
      <div class="container">
        <div class="label" style="margin-bottom: 1.5rem;">The Results</div>
        <AnimatedText client:only="react" text={result} as="p" className="display-sm" style={{ color: 'var(--white)', marginBottom: '3rem' }} />
        <div class="work-outcomes-grid" style="display: grid; grid-template-columns: repeat(2,1fr); gap: 1.25rem;">
          {outcomes.map(o => (
            <div style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem; border: 1px solid var(--border); border-radius: var(--radius); background: var(--gray-800);">
              <span style="color: var(--white); font-size: 1.1rem; flex-shrink: 0;">✓</span>
              <span style="color: var(--gray-200); font-size: 0.95rem;">{o}</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <MarqueeSection client:only="react" />

    <!-- CTA -->
    <section style="padding: clamp(4rem,8vw,8rem) 0; background: var(--black); text-align: center;">
      <div class="container" style="display: flex; flex-direction: column; align-items: center; gap: 2rem;">
        <AnimatedText client:only="react" text="Want results like these?" as="h2" className="display-md" />
        <div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
          <MagneticButton client:only="react" href="/contact" variant="primary" size="lg">Start a Project →</MagneticButton>
          <MagneticButton client:only="react" href="/work" variant="outline" size="lg">More Work</MagneticButton>
        </div>
      </div>
    </section>
  </main>

  <Footer client:only="react" />
</Layout>

<style>
  /* Meta row: 4-col → 2-col → 1-col */
  @media (max-width: 640px) {
    .work-meta-grid { grid-template-columns: repeat(2,1fr) !important; }
  }
  @media (max-width: 400px) {
    .work-meta-grid { grid-template-columns: 1fr !important; }
  }
  /* Challenge / Approach 2-col → 1-col */
  @media (max-width: 768px) {
    .work-content-grid { grid-template-columns: 1fr !important; gap: 2.5rem !important; }
  }
  /* Results outcomes 2-col → 1-col */
  @media (max-width: 560px) {
    .work-outcomes-grid { grid-template-columns: 1fr !important; }
  }
</style>
