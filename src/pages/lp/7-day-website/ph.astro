---
import LpLayout from '../../../layouts/LpLayout.astro';
import LpForm   from '../../../components/lp/LpForm.tsx';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "7-Day Website Design & Development",
    "description": "Professional custom website design and development delivered in 7 days for Philippine businesses. Starting at ₱28,000. Mobile-ready and SEO-optimized.",
    "provider": {
      "@type": "Organization",
      "name": "Fazed Digital",
      "url": "https://fazeddigital.com",
      "email": "info@fazeddigital.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Iligan City",
        "addressRegion": "Lanao del Norte",
        "addressCountry": "PH"
      }
    },
    "offers": [
      { "@type": "Offer", "name": "Starter Website Package", "price": "28000", "priceCurrency": "PHP", "availability": "https://schema.org/InStock", "description": "5-page professional website, mobile-responsive, basic SEO, contact form, 7-day delivery." },
      { "@type": "Offer", "name": "Growth Website Package",  "price": "49000", "priceCurrency": "PHP", "availability": "https://schema.org/InStock", "description": "8-page custom website, advanced SEO, blog setup, Google Analytics, 7-day delivery." },
      { "@type": "Offer", "name": "Pro Website Package",     "price": "85000", "priceCurrency": "PHP", "availability": "https://schema.org/InStock", "description": "10+ page fully custom website, e-commerce ready, performance optimised, unlimited revisions, 7-day delivery." }
    ],
    "serviceType": "Web Design and Development",
    "areaServed": "Philippines",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Website Packages"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What do I need to provide to get started?", "acceptedAnswer": { "@type": "Answer", "text": "Just your business details, brand assets (logo if you have one), preferred colors or style references, and any content — text and images — for the site. We guide you through everything on Day 1 with a short brief form." } },
      { "@type": "Question", "name": "Is the 7-day website delivery actually guaranteed?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. As long as you provide all required assets and feedback within 24 hours during the review phase, we guarantee delivery in 7 business days. If we miss the deadline due to our side, you get a full refund of 20% of the project fee." } },
      { "@type": "Question", "name": "What platform will my website be built on?", "acceptedAnswer": { "@type": "Answer", "text": "We primarily build on WordPress (for easy self-management) or Astro (for maximum performance and SEO). We recommend the best fit based on your needs during the Day 1 kickoff call." } },
      { "@type": "Question", "name": "What if I need more pages or custom features?", "acceptedAnswer": { "@type": "Answer", "text": "Additional pages are available at ₱4,500/page. Complex features like booking systems, membership portals, or custom e-commerce are scoped separately. We discuss everything upfront — no surprise charges." } },
      { "@type": "Question", "name": "Do you offer ongoing website maintenance?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We offer monthly maintenance plans starting at ₱5,500/month covering updates, backups, security monitoring, uptime checks, and minor content changes." } },
      { "@type": "Question", "name": "What if I'm not happy with the design?", "acceptedAnswer": { "@type": "Answer", "text": "Every package includes revision rounds — 2 for Starter, 3 for Growth, unlimited for Pro. We iterate until you're 100% happy. Our live portfolio is proof we deliver quality." } },
      { "@type": "Question", "name": "Do you accept GCash, bank transfer, or other local payment methods?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We accept GCash, Maya, BPI/BDO bank transfer, and other major Philippine banks. A 50% downpayment is required to start, with the balance due upon launch." } }
    ]
  }
];

const testimonials = [
  {
    quote: "I've worked with agencies that took 3 months and charged 10× more. Fazed had our full site live in 6 days. Our phone hasn't stopped ringing since launch.",
    name: 'James R.',
    role: 'Owner',
    company: 'A Framing Company',
    initials: 'JR',
  },
  {
    quote: "The brief process made everything effortless. They understood our brand on day one and the site was live before we even expected it. Clients constantly compliment the design.",
    name: 'Maria L.',
    role: 'Founder',
    company: 'Cleen & Green',
    initials: 'ML',
  },
  {
    quote: "Building our platform in under a week seemed impossible. The team delivered exactly what we envisioned and flagged improvements we hadn't thought of. Truly impressive work.",
    name: 'Carlos M.',
    role: 'Co-founder',
    company: 'CrateOnScene',
    initials: 'CM',
  },
];

const pricing = [
  {
    name: 'Starter',
    price: '₱28,000',
    tagline: 'Para sa mga bagong negosyo',
    features: [
      '5 custom-designed pages',
      'Mobile-responsive layout',
      'On-page SEO setup',
      'Contact form',
      '2 revision rounds',
      '7-day guaranteed delivery',
    ],
    popular: false,
    cta: 'Get Started',
  },
  {
    name: 'Growth',
    price: '₱49,000',
    tagline: 'Best para sa lumalagong negosyo',
    features: [
      '8 custom-designed pages',
      'Custom design system',
      'Advanced on-page SEO',
      'Blog & CMS setup',
      'Google Analytics + Search Console',
      '3 revision rounds',
      '7-day guaranteed delivery',
    ],
    popular: true,
    cta: 'Most Popular',
  },
  {
    name: 'Pro',
    price: '₱85,000',
    tagline: 'Para sa mga negosyong handa nang lumago',
    features: [
      '10+ custom pages',
      'Full brand integration',
      'E-commerce ready',
      'Performance optimised (<2s load)',
      'Priority support',
      'Unlimited revisions',
      '7-day guaranteed delivery',
    ],
    popular: false,
    cta: 'Go Pro',
  },
];

const process = [
  {
    day: 'Day 1',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`,
    title: 'Kickoff & Brief',
    desc: 'You fill our quick brief, share brand assets and references. We align on goals and timeline.',
  },
  {
    day: 'Day 2–3',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19 7-7 3 3-7 7-3-3z"/><path d="m18 13-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="m2 2 7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`,
    title: 'Design',
    desc: 'We craft your custom mockups. You review and provide feedback within 24 hours.',
  },
  {
    day: 'Day 4–5',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title: 'Development',
    desc: 'We build the full site — mobile-first, fast-loading, and fully SEO-optimised.',
  },
  {
    day: 'Day 6',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
    title: 'Review & Revise',
    desc: 'You test on our staging server. We apply final revisions based on your feedback.',
  },
  {
    day: 'Day 7',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    title: 'Launch',
    desc: 'Your website goes live. We handle domain connection, hosting setup, and full handover.',
  },
];

const faqs = [
  { q: 'What do I need to provide to get started?',                         a: 'Just your business details, brand assets (logo if you have one), preferred colors or style references, and any content — text and images — for the site. We guide you through everything on Day 1 with a short brief form.' },
  { q: 'Is the 7-day delivery actually guaranteed?',                        a: 'Yes. As long as you provide all required assets and feedback within 24 hours during the review phase, we guarantee delivery in 7 business days. If we miss the deadline due to our side, you get a 20% discount on the project fee.' },
  { q: 'What platform will my website be built on?',                        a: 'We primarily build on WordPress (for easy self-management) or Astro (for maximum performance and SEO). We recommend the best fit based on your needs during the Day 1 kickoff.' },
  { q: 'What if I need more pages or custom features?',                     a: 'Additional pages are available at ₱4,500/page. Complex features like booking systems or membership portals are scoped separately — always discussed upfront with no surprise charges.' },
  { q: 'Do you offer ongoing website maintenance?',                         a: 'Yes. Monthly maintenance plans start at ₱5,500/month and cover updates, backups, security monitoring, and minor content changes.' },
  { q: "What if I'm not happy with the design?",                            a: "Every package includes revision rounds — 2 for Starter, 3 for Growth, unlimited for Pro. We iterate until you're 100% happy. Our live portfolio is proof we deliver quality." },
  { q: 'What payment methods do you accept?',                               a: 'We accept GCash, Maya, BPI, BDO, UnionBank, and other major Philippine banks. A 50% downpayment is required to start, with the balance due upon launch.' },
];
---

<LpLayout
  title="Magpaawa ng Website sa 7 Araw | Mula ₱28,000 | Fazed Digital"
  description="Professional custom websites para sa mga negosyo sa Pilipinas — naihatid sa 7 araw. Mula ₱28,000. Mobile-ready, SEO-optimized, at built to convert. Limitadong slots."
  canonical="https://fazeddigital.com/lp/7-day-website/ph"
  schema={schema}
>

  <!-- ─── HEADER ──────────────────────────────────────────── -->
  <header class="lp-header">
    <div class="lp-container" style="display:flex; align-items:center; justify-content:space-between; padding-top:1.25rem; padding-bottom:1.25rem;">
      <a href="https://fazeddigital.com" aria-label="Fazed Digital home" style="text-decoration:none; display:flex; align-items:center; gap:0.55rem;">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="372 205 755 1089"
          style="width:1.3rem; height:auto; color:#C9FF57; flex-shrink:0;"
          aria-hidden="true">
          <g transform="translate(0 1500) scale(0.1 -0.1)" fill="currentColor">
            <path d="M7445 12847 c-22 -13 -348 -206 -725 -429 -377 -222 -723 -427 -770 -455 -47 -27 -506 -299 -1020 -603 -514 -303 -969 -572 -1012 -597 -43 -25 -87 -56 -98 -70 -20 -26 -20 -37 -20 -3282 0 -2590 3 -3261 13 -3274 17 -22 3645 -2000 3679 -2005 26 -4 692 354 2443 1313 143 79 481 263 750 409 270 147 496 274 503 283 19 26 18 1456 -2 1472 -10 8 -27 4 -72 -20 -32 -18 -854 -465 -1826 -995 -972 -530 -1776 -964 -1787 -964 -24 0 -2303 1299 -2338 1332 l-23 21 0 2517 0 2517 23 20 c12 11 326 199 697 418 371 219 945 558 1275 753 884 522 1310 774 1495 883 118 70 166 103 168 118 3 18 -78 61 -637 341 -353 176 -649 320 -658 320 -10 0 -36 -11 -58 -23z"/>
            <path d="M9455 11664 c-28 -15 -295 -161 -595 -324 -300 -163 -624 -340 -720 -392 -96 -53 -195 -107 -220 -121 -25 -13 -241 -131 -480 -262 -239 -130 -500 -272 -580 -316 -80 -44 -341 -186 -580 -317 -319 -174 -438 -244 -447 -262 -17 -33 -19 -4306 -2 -4342 8 -18 164 -100 645 -341 349 -174 643 -317 653 -317 11 0 21 9 25 23 3 12 6 949 6 2083 l0 2061 23 20 c12 11 398 242 857 513 459 271 900 532 980 579 80 48 511 303 958 566 447 264 822 488 833 498 11 10 17 23 13 28 -9 15 -1281 649 -1302 649 -9 0 -40 -12 -67 -26z"/>
            <path d="M11135 10316 c-11 -7 -74 -42 -140 -78 -66 -36 -230 -126 -365 -201 -720 -396 -2614 -1437 -2698 -1482 -30 -16 -62 -40 -73 -53 -19 -24 -19 -70 -19 -1918 0 -1695 2 -1894 15 -1908 14 -14 79 16 664 309 366 182 651 331 655 340 3 9 6 537 6 1174 l0 1158 23 20 c12 12 456 274 987 583 531 309 975 573 988 586 l22 25 0 718 c0 725 -1 742 -34 740 -6 0 -20 -6 -31 -13z"/>
          </g>
        </svg>
        <span style="font-family:var(--font-display); font-size:1.35rem; font-weight:700; color:var(--white); letter-spacing:-0.02em;">
          Fazed<span style="font-weight:300; color:var(--gray-500);"> Digital</span>
        </span>
      </a>
      <a href="#get-started" class="lp-btn-outline" style="font-size:0.85rem; padding:0.55rem 1.1rem;">
        Mag-inquire →
      </a>
    </div>
  </header>

  <!-- ─── HERO ────────────────────────────────────────────── -->
  <section class="lp-section" style="padding-top:clamp(3rem,8vw,6rem); padding-bottom:clamp(3rem,8vw,5rem); border-bottom:1px solid var(--border);">
    <div class="lp-container" style="text-align:center; max-width:820px;">

      <div class="lp-reveal" style="display:inline-flex; align-items:center; gap:0.5rem; background:rgba(201,255,87,0.1); border:1px solid rgba(201,255,87,0.25); border-radius:2rem; padding:0.4rem 0.9rem; margin-bottom:2rem;">
        <span style="font-size:0.7rem; font-family:var(--font-mono); letter-spacing:0.12em; text-transform:uppercase; color:var(--accent);">🇵🇭 Philippine Pricing — Iligan City, PH</span>
      </div>

      <h1 class="lp-reveal" style="font-family:var(--font-display); font-size:clamp(2.8rem,7vw,5.5rem); font-weight:700; line-height:1; letter-spacing:-0.03em; color:var(--white); margin-bottom:1.5rem;">
        Your Website,<br/><span style="color:var(--accent);">Live in 7 Days.</span>
      </h1>

      <p class="lp-reveal" style="font-size:clamp(1rem,2vw,1.2rem); color:var(--gray-400); line-height:1.65; max-width:620px; margin:0 auto 2.5rem;">
        We design, build, and launch professional websites for Philippine businesses —
        fully custom, mobile-ready, and SEO-optimised.
        <strong style="color:var(--white);">Starting at ₱28,000. Guaranteed.</strong>
      </p>

      <div class="lp-reveal" style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-bottom:3rem;">
        <a href="#get-started" class="lp-btn-primary">Mag-inquire Ngayon →</a>
        <a href="#pricing" class="lp-btn-outline">Tingnan ang Presyo</a>
      </div>

      <!-- Trust bar -->
      <div class="lp-reveal lp-trust-bar">
        <div class="lp-trust-item">
          <span class="lp-trust-num">12+</span>
          <span class="lp-trust-label">Websites Delivered</span>
        </div>
        <div class="lp-trust-divider"></div>
        <div class="lp-trust-item">
          <span class="lp-trust-num">100%</span>
          <span class="lp-trust-label">On-Time Delivery</span>
        </div>
        <div class="lp-trust-divider"></div>
        <div class="lp-trust-item">
          <span class="lp-trust-num">7x</span>
          <span class="lp-trust-label">Faster Than Industry Avg</span>
        </div>
        <div class="lp-trust-divider"></div>
        <div class="lp-trust-item">
          <span class="lp-trust-num">₱28K</span>
          <span class="lp-trust-label">Starting Price</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── PAIN COMPARISON ─────────────────────────────────── -->
  <section class="lp-section" style="padding:clamp(3rem,6vw,4.5rem) 0; border-bottom:1px solid var(--border);">
    <div class="lp-container">
      <div class="lp-reveal" style="text-align:center; margin-bottom:2.75rem;">
        <h2 style="font-family:var(--font-display); font-size:clamp(1.75rem,3.5vw,2.5rem); font-weight:700; letter-spacing:-0.025em; color:var(--white); line-height:1.15;">
          Bakit hindi na lang mag-hire ng<br/>ibang agency?
        </h2>
        <p style="color:var(--gray-500); font-size:0.9rem; margin-top:0.6rem;">Ito ang katotohanan.</p>
      </div>

      <div class="comparison-grid lp-reveal">
        <div class="comparison-col comparison-col--bad">
          <div class="comparison-col-header">Typical Agency</div>
          <ul class="comparison-list">
            {[
              '6–10 week delivery timeline',
              '₱150,000–₱500,000+ minimum budget',
              'Hourly rates — surprise invoices',
              'Vague revision processes',
              'Multiple handoffs & delays',
              'Lock-in contracts',
            ].map(item => (
              <li>
                <span class="cmp-icon cmp-icon--bad">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <div class="comparison-col comparison-col--good">
          <div class="comparison-col-header">
            Fazed Digital
            <span class="comparison-badge">Kami 'to</span>
          </div>
          <ul class="comparison-list">
            {[
              'Live in 7 days, guaranteed',
              'Fixed price mula ₱28,000',
              'One flat fee — walang sorpresa',
              'Structured 5-step process',
              'One dedicated team, direct line',
              'Full ownership — no lock-in',
            ].map(item => (
              <li>
                <span class="cmp-icon cmp-icon--good">
                  <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </span>
                {item}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── PRICING ──────────────────────────────────────────── -->
  <section id="pricing" class="lp-section" style="background:var(--black);">
    <div class="lp-container">
      <div class="lp-reveal" style="text-align:center; margin-bottom:3.5rem;">
        <div class="label" style="margin-bottom:1rem;">Simple, Transparent Pricing</div>
        <h2 style="font-family:var(--font-display); font-size:clamp(2rem,4vw,3rem); font-weight:700; letter-spacing:-0.025em; color:var(--white); line-height:1.1;">
          Piliin ang package.<br/>Kami na ang bahala sa iba.
        </h2>
        <p style="color:var(--gray-500); font-size:0.85rem; margin-top:0.75rem;">
          Lahat ng presyo sa Philippine Peso. Tinatanggap: GCash, Maya, bank transfer.
        </p>
      </div>

      <div class="pricing-grid">
        {pricing.map((tier) => (
          <article
            class={`pricing-card ${tier.popular ? 'pricing-card--popular' : ''}`}
            aria-label={`${tier.name} package at ${tier.price}`}
          >
            {tier.popular && (
              <div class="pricing-popular-badge">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                Most Popular
              </div>
            )}
            <div class="pricing-card-header">
              <div style="font-family:var(--font-mono); font-size:0.65rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--gray-500); margin-bottom:0.5rem;">
                {tier.name}
              </div>
              <div class="pricing-price">{tier.price}</div>
              <div style="font-size:0.85rem; color:var(--gray-500); margin-top:0.4rem;">{tier.tagline}</div>
            </div>
            <ul class="pricing-features" role="list">
              {tier.features.map((f) => (
                <li>
                  <span style="color:var(--accent); margin-right:0.6rem;" aria-hidden="true">✓</span>
                  {f}
                </li>
              ))}
            </ul>
            <a href="#get-started" class={tier.popular ? 'lp-btn-primary' : 'lp-btn-outline'} style="display:block; text-align:center;">
              {tier.popular ? 'Mag-inquire →' : 'Piliin Ito →'}
            </a>
          </article>
        ))}
      </div>

      <p class="lp-reveal" style="text-align:center; margin-top:2rem; color:var(--gray-500); font-size:0.85rem;">
        May custom na kailangan? <a href="mailto:info@fazeddigital.com" style="color:var(--accent);">Mag-email sa amin</a> at iki-scope namin ito para sa iyo. Walang commitment.
      </p>
    </div>
  </section>

  <!-- ─── PAYMENT METHODS ───────────────────────────────────── -->
  <section class="lp-section" style="padding:clamp(2rem,4vw,3rem) 0; border-top:1px solid var(--border); border-bottom:1px solid var(--border); background:rgba(255,255,255,0.015);">
    <div class="lp-container">
      <div class="lp-reveal" style="text-align:center; margin-bottom:1.75rem;">
        <div class="label" style="margin-bottom:0.5rem;">Accepted Payments</div>
        <p style="color:var(--gray-500); font-size:0.875rem;">50% downpayment to start · Balance upon launch</p>
      </div>
      <div class="lp-reveal payment-methods">
        {['GCash', 'Maya', 'BPI', 'BDO', 'UnionBank', 'Metrobank'].map(p => (
          <div class="payment-badge">{p}</div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── TESTIMONIALS ───────────────────────────────────────── -->
  <section class="lp-section" style="background:var(--black);">
    <div class="lp-container">
      <div class="lp-reveal" style="text-align:center; margin-bottom:3rem;">
        <div class="label" style="margin-bottom:1rem;">Client Reviews</div>
        <h2 style="font-family:var(--font-display); font-size:clamp(2rem,4vw,3rem); font-weight:700; letter-spacing:-0.025em; color:var(--white);">
          Huwag kaming paniwalaan. Tingnan ang aming gawa.
        </h2>
      </div>

      <div class="testimonials-grid">
        {testimonials.map(t => (
          <div class="lp-reveal testimonial-card">
            <div class="testimonial-stars">
              {[...Array(5)].map(() => (
                <svg width="14" height="14" viewBox="0 0 24 24" fill="var(--accent)" stroke="none" aria-hidden="true">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
              ))}
            </div>
            <p class="testimonial-quote">"{t.quote}"</p>
            <div class="testimonial-author">
              <div class="testimonial-avatar">{t.initials}</div>
              <div>
                <div class="testimonial-name">{t.name}</div>
                <div class="testimonial-role">{t.role} · {t.company}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── PROCESS ──────────────────────────────────────────── -->
  <section class="lp-section" style="background:rgba(255,255,255,0.015); border-top:1px solid var(--border); border-bottom:1px solid var(--border);">
    <div class="lp-container">
      <div class="lp-reveal" style="text-align:center; margin-bottom:3.5rem;">
        <div class="label" style="margin-bottom:1rem;">How It Works</div>
