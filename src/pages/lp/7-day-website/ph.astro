<!-- ─── GSAP ANIMATIONS ─────────────────────────────────────── -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Generic reveal for .lp-reveal elements
  gsap.utils.toArray<HTMLElement>('.lp-reveal').forEach((el) => {
    gsap.from(el, {
      y: 35, autoAlpha: 0, duration: 0.85, ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
    });
  });

  // Pricing cards stagger
  gsap.from('.pricing-card', {
    y: 50, autoAlpha: 0, duration: 0.75, stagger: 0.13, ease: 'power3.out',
    scrollTrigger: { trigger: '.pricing-grid', start: 'top 82%', toggleActions: 'play none none none' },
  });

  // Process steps stagger
  gsap.from('.process-step', {
    y: 30, autoAlpha: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out',
    scrollTrigger: { trigger: '.process-grid', start: 'top 82%', toggleActions: 'play none none none' },
  });

  // Testimonial cards stagger
  gsap.from('.testimonial-card', {
    y: 40, autoAlpha: 0, duration: 0.7, stagger: 0.14, ease: 'power3.out',
    scrollTrigger: { trigger: '.testimonials-grid', start: 'top 82%', toggleActions: 'play none none none' },
  });

  // Comparison columns
  gsap.from('.comparison-col', {
    y: 30, autoAlpha: 0, duration: 0.65, stagger: 0.15, ease: 'power2.out',
    scrollTrigger: { trigger: '.comparison-grid', start: 'top 85%', toggleActions: 'play none none none' },
  });

  // FAQ — smooth GSAP accordion
  const faqItems = Array.from(document.querySelectorAll<HTMLDetailsElement>('.faq-item'));

  function openFaq(item: HTMLDetailsElement) {
    const answer  = item.querySelector<HTMLElement>('.faq-answer')!;
    const chevron = item.querySelector<HTMLElement>('.faq-chevron');
    item.open = true;
    const target = answer.scrollHeight;
    gsap.fromTo(answer,
      { height: 0, opacity: 0 },
      { height: target, opacity: 1, duration: 0.38, ease: 'power2.out',
        onComplete: () => gsap.set(answer, { height: 'auto' }) }
    );
    if (chevron) chevron.textContent = '−';
  }

  function closeFaq(item: HTMLDetailsElement) {
    const answer  = item.querySelector<HTMLElement>('.faq-answer')!;
    const chevron = item.querySelector<HTMLElement>('.faq-chevron');
    gsap.to(answer, {
      height: 0, opacity: 0, duration: 0.28, ease: 'power2.in',
      onComplete: () => { item.open = false; gsap.set(answer, { clearProps: 'height,opacity' }); }
    });
    if (chevron) chevron.textContent = '+';
  }

  faqItems.forEach((item) => {
    const summary = item.querySelector('summary')!;
    summary.addEventListener('click', (e) => {
      e.preventDefault();
      if (item.open) {
        closeFaq(item);
      } else {
        faqItems.forEach((other) => { if (other !== item && other.open) closeFaq(other); });
        openFaq(item);
      }
    });
  });

  if (faqItems[0]) openFaq(faqItems[0]);
</script>

