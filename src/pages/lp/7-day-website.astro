<!-- ─── GSAP ANIMATIONS ─────────────────────────────────────── -->
<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Generic reveal for .lp-reveal elements
  gsap.utils.toArray<HTMLElement>('.lp-reveal').forEach((el) => {
    gsap.from(el, {
      y: 35, autoAlpha: 0, duration: 0.85, ease: 'power3.out',
      scrollTrigger: { trigger: el, start: 'top 88%', toggleActions: 'play none none none' },
    });
  });

  // Pricing cards stagger
  gsap.from('.pricing-card', {
    y: 50, autoAlpha: 0, duration: 0.75, stagger: 0.13, ease: 'power3.out',
    scrollTrigger: { trigger: '.pricing-grid', start: 'top 82%', toggleActions: 'play none none none' },
  });

  // Process steps stagger
  gsap.from('.process-step', {
    y: 30, autoAlpha: 0, duration: 0.6, stagger: 0.1, ease: 'power2.out',
    scrollTrigger: { trigger: '.process-grid', start: 'top 82%', toggleActions: 'play none none none' },
  });

  // FAQ chevron toggle
  document.querySelectorAll<HTMLElement>('.faq-item').forEach((item) => {
    item.addEventListener('toggle', () => {
      const chevron = item.querySelector<HTMLElement>('.faq-chevron');
      if (chevron) chevron.textContent = item.open ? '−' : '+';
    });
  });
</script>

