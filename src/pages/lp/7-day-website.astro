---
import LpLayout from '../../layouts/LpLayout.astro';
import LpForm   from '../../components/lp/LpForm.tsx';

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "7-Day Website Design & Development",
    "description": "Professional custom website design and development delivered in 7 days for small businesses. Starting at $499. Mobile-ready and SEO-optimized.",
    "provider": {
      "@type": "Organization",
      "name": "Fazed Digital",
      "url": "https://fazeddigital.com",
      "email": "info@fazeddigital.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Iligan City",
        "addressRegion": "Lanao del Norte",
        "addressCountry": "PH"
      }
    },
    "offers": [
      { "@type": "Offer", "name": "Starter Website Package", "price": "499",  "priceCurrency": "USD", "availability": "https://schema.org/InStock", "description": "5-page professional website, mobile-responsive, basic SEO, contact form, 7-day delivery." },
      { "@type": "Offer", "name": "Growth Website Package",  "price": "899",  "priceCurrency": "USD", "availability": "https://schema.org/InStock", "description": "8-page custom website, advanced SEO, blog setup, Google Analytics, 7-day delivery." },
      { "@type": "Offer", "name": "Pro Website Package",     "price": "1499", "priceCurrency": "USD", "availability": "https://schema.org/InStock", "description": "10+ page fully custom website, e-commerce ready, performance optimised, unlimited revisions, 7-day delivery." }
    ],
    "serviceType": "Web Design and Development",
    "areaServed": "Worldwide",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Website Packages"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      { "@type": "Question", "name": "What do I need to provide to get started?", "acceptedAnswer": { "@type": "Answer", "text": "Just your business details, brand assets (logo if you have one), preferred colors or style references, and any content — text and images — for the site. We guide you through everything on Day 1 with a short brief form." } },
      { "@type": "Question", "name": "Is the 7-day website delivery actually guaranteed?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. As long as you provide all required assets and feedback within 24 hours during the review phase, we guarantee delivery in 7 business days. If we miss the deadline due to our side, you get a full refund of 20% of the project fee." } },
      { "@type": "Question", "name": "What platform will my website be built on?", "acceptedAnswer": { "@type": "Answer", "text": "We primarily build on WordPress (for easy self-management) or Astro (for maximum performance and SEO). We recommend the best fit based on your needs during the Day 1 kickoff call." } },
      { "@type": "Question", "name": "What if I need more pages or custom features?", "acceptedAnswer": { "@type": "Answer", "text": "Additional pages are available at $79/page. Complex features like booking systems, membership portals, or custom e-commerce are scoped separately. We discuss everything upfront — no surprise charges." } },
      { "@type": "Question", "name": "Do you offer ongoing website maintenance?", "acceptedAnswer": { "@type": "Answer", "text": "Yes. We offer monthly maintenance plans starting at $99/month covering updates, backups, security monitoring, uptime checks, and minor content changes." } },
      { "@type": "Question", "name": "What if I'm not happy with the design?", "acceptedAnswer": { "@type": "Answer", "text": "Every package includes revision rounds — 2 for Starter, 3 for Growth, unlimited for Pro. We iterate until you're 100% happy. Our live portfolio is proof we deliver quality." } }
    ]
  }
];

const pricing = [
  {
    name: 'Starter',
    price: '$499',
    tagline: 'For new businesses getting online',
    features: [
      '5 custom-designed pages',
      'Mobile-responsive layout',
      'On-page SEO setup',
      'Contact form',
      '2 revision rounds',
      '7-day guaranteed delivery',
    ],
    popular: false,
    cta: 'Get Started',
  },
  {
    name: 'Growth',
    price: '$899',
    tagline: 'Best for growing small businesses',
    features: [
      '8 custom-designed pages',
      'Custom design system',
      'Advanced on-page SEO',
      'Blog & CMS setup',
      'Google Analytics + Search Console',
      '3 revision rounds',
      '7-day guaranteed delivery',
    ],
    popular: true,
    cta: 'Most Popular',
  },
  {
    name: 'Pro',
    price: '$1,499',
    tagline: 'For businesses ready to scale',
    features: [
      '10+ custom pages',
      'Full brand integration',
      'E-commerce ready',
      'Performance optimised (<2s load)',
      'Priority support',
      'Unlimited revisions',
      '7-day guaranteed delivery',
    ],
    popular: false,
    cta: 'Go Pro',
  },
];

const process = [
  {
    day: 'Day 1',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`,
    title: 'Kickoff & Brief',
    desc: 'You fill our quick brief, share brand assets and references. We align on goals and timeline.',
  },
  {
    day: 'Day 2–3',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19 7-7 3 3-7 7-3-3z"/><path d="m18 13-1.5-7.5L2 2l3.5 14.5L13 18l5-5z"/><path d="m2 2 7.586 7.586"/><circle cx="11" cy="11" r="2"/></svg>`,
    title: 'Design',
    desc: 'We craft your custom mockups. You review and provide feedback within 24 hours.',
  },
  {
    day: 'Day 4–5',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
    title: 'Development',
    desc: 'We build the full site — mobile-first, fast-loading, and fully SEO-optimised.',
  },
  {
    day: 'Day 6',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
    title: 'Review & Revise',
    desc: 'You test on our staging server. We apply final revisions based on your feedback.',
  },
  {
    day: 'Day 7',
    icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>`,
    title: 'Launch',
    desc: 'Your website goes live. We handle domain connection, hosting setup, and full handover.',
  },
];

const faqs = [
  { q: 'What do I need to provide to get started?',            a: 'Just your business details, brand assets (logo if you have one), preferred colors or style references, and any content — text and images — for the site. We guide you through everything on Day 1 with a short brief form.' },
  { q: 'Is the 7-day delivery actually guaranteed?',           a: 'Yes. As long as you provide all required assets and feedback within 24 hours during the review phase, we guarantee delivery in 7 business days. If we miss the deadline due to our side, you get a 20% discount on the project fee.' },
  { q: 'What platform will my website be built on?',           a: 'We primarily build on WordPress (for easy self-management) or Astro (for maximum performance and SEO). We recommend the best fit based on your needs during the Day 1 kickoff.' },
  { q: 'What if I need more pages or custom features?',        a: 'Additional pages are available at $79/page. Complex features like booking systems or membership portals are scoped separately — always discussed upfront with no surprise charges.' },
  { q: 'Do you offer ongoing website maintenance?',            a: 'Yes. Monthly maintenance plans start at $99/month and cover updates, backups, security monitoring, and minor content changes.' },
  { q: "What if I'm not happy with the design?",               a: "Every package includes revision rounds — 2 for Starter, 3 for Growth, unlimited for Pro. We iterate until you're 100% happy. Our live portfolio is proof we deliver quality." },
];
---

<LpLayout
  title="Get a Professional Website in 7 Days | From $499 | Fazed Digital"
  description="Professional custom websites for small businesses, delivered in 7 days. Starting at $499. Mobile-ready, SEO-optimized, and built to convert. Limited spots available."
  canonical="https://fazeddigital.com/lp/7-day-website"
  schema={schema}
>

  <!-- ─── HEADER ──────────────────────────────────────────── -->
  <header class="lp-header">
    <div class="lp-container" style="display:flex; align-items:center; justify-content:space-between; padding-top:1.25rem; padding-bottom:1.25rem;">
      <a href="https://fazeddigital.com" aria-label="Fazed Digital home" style="text-decoration:none;">
        <span style="font-family:var(--font-display); font-size:1.25rem; font-weight:700; color:var(--white); letter-spacing:-0.03em;">
          Fazed<span style="color:var(--accent);">.</span>
        </span>
      </a>
      <a href="#get-started" class="lp-btn-outline" style="font-size:0.85rem; padding:0.55rem 1.1rem;">
        Get Started →
      </a>
    </div>
  </header>

  <!-- ─── HERO ────────────────────────────────────────────── -->
  <section class="lp-section" style="padding-top:clamp(3rem,8vw,6rem); padding-bottom:clamp(3rem,8vw,5rem); border-bottom:1px solid var(--border);">
    <div class="lp-container" style="text-align:center; max-width:820px;">

      <div class="lp-reveal" style="display:inline-flex; align-items:center; gap:0.5rem; background:rgba(201,255,87,0.1); border:1px solid rgba(201,255,87,0.25); border-radius:2rem; padding:0.4rem 0.9rem; margin-bottom:2rem;">
        <span style="font-size:0.7rem; font-family:var(--font-mono); letter-spacing:0.12em; text-transform:uppercase; color:var(--accent);">⚡ Fast-Track Web Package</span>
      </div>

      <h1 class="lp-reveal" style="font-family:var(--font-display); font-size:clamp(2.8rem,7vw,5.5rem); font-weight:700; line-height:1; letter-spacing:-0.03em; color:var(--white); margin-bottom:1.5rem;">
        Your Website,<br/><span style="color:var(--accent);">Live in 7 Days.</span>
      </h1>

      <p class="lp-reveal" style="font-size:clamp(1rem,2vw,1.2rem); color:var(--gray-400); line-height:1.65; max-width:620px; margin:0 auto 2.5rem;">
        We design, build, and launch professional websites for small businesses —
        fully custom, mobile-ready, and SEO-optimised.
        <strong style="color:var(--white);">Starting at $499. Guaranteed.</strong>
      </p>

      <div class="lp-reveal" style="display:flex; gap:1rem; justify-content:center; flex-wrap:wrap; margin-bottom:3rem;">
        <a href="#get-started" class="lp-btn-primary">Claim Your Spot →</a>
        <a href="#pricing" class="lp-btn-outline">See Pricing</a>
      </div>

      <!-- Trust bar -->
      <div class="lp-reveal lp-trust-bar">
        <div class="lp-trust-item">
          <span class="lp-trust-num">12+</span>
          <span class="lp-trust-label">Websites Delivered</span>
        </div>
        <div class="lp-trust-divider"></div>
        <div class="lp-trust-item">
          <span class="lp-trust-num">100%</span>
          <span class="lp-trust-label">On-Time Delivery</span>
        </div>
        <div class="lp-trust-divider"></div>
        <div class="lp-trust-item">
          <span class="lp-trust-num">7x</span>
          <span class="lp-trust-label">Faster Than Industry Avg</span>
        </div>
        <div class="lp-trust-divider"></div>
        <div class="lp-trust-item">
          <span class="lp-trust-num">$499</span>
          <span class="lp-trust-label">Starting Price</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ─── PRICING ──────────────────────────────────────────── -->
  <section id="pricing" class="lp-section" style="background:var(--black);">
    <div class="lp-container">
      <div class="lp-reveal" style="text-align:center; margin-bottom:3.5rem;">
        <div class="label" style="margin-bottom:1rem;">Simple, Transparent Pricing</div>
        <h2 style="font-family:var(--font-display); font-size:clamp(2rem,4vw,3rem); font-weight:700; letter-spacing:-0.025em; color:var(--white); line-height:1.1;">
          Pick your package.<br/>We handle the rest.
        </h2>
      </div>

      <div class="pricing-grid">
        {pricing.map((tier) => (
          <article
            class={`pricing-card ${tier.popular ? 'pricing-card--popular' : ''}`}
            aria-label={`${tier.name} package at ${tier.price}`}
          >
            {tier.popular && (
              <div class="pricing-popular-badge">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor" stroke="none" aria-hidden="true"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                Most Popular
              </div>
            )}
            <div class="pricing-card-header">
              <div style="font-family:var(--font-mono); font-size:0.65rem; letter-spacing:0.14em; text-transform:uppercase; color:var(--gray-500); margin-bottom:0.5rem;">
                {tier.name}
              </div>
              <div class="pricing-price">{tier.price}</div>
              <div style="font-size:0.85rem; color:var(--gray-500); margin-top:0.4rem;">{tier.tagline}</div>
            </div>
            <ul class="pricing-features" role="list">
              {tier.features.map((f) => (
                <li>
                  <span style="color:var(--accent); margin-right:0.6rem;" aria-hidden="true">✓</span>
                  {f}
                </li>
              ))}
            </ul>
            <a href="#get-started" class={tier.popular ? 'lp-btn-primary' : 'lp-btn-outline'} style="display:block; text-align:center;">
              {tier.popular ? 'Get Started →' : 'Choose Plan →'}
            </a>
          </article>
        ))}
      </div>

      <p class="lp-reveal" style="text-align:center; margin-top:2rem; color:var(--gray-500); font-size:0.85rem;">
        Need something custom? <a href="mailto:info@fazeddigital.com" style="color:var(--accent);">Email us</a> and we'll scope it together. No commitment required.
      </p>
    </div>
  </section>

  <!-- ─── PROCESS ──────────────────────────────────────────── -->
  <section class="lp-section" style="background:rgba(255,255,255,0.015); border-top:1px solid var(--border); border-bottom:1px solid var(--border);">
    <div class="lp-container">
      <div class="lp-reveal" style="text-align:center; margin-bottom:3.5rem;">
        <div class="label" style="margin-bottom:1rem;">How It Works</div>
        <h2 style="font-family:var(--font-display); font-size:clamp(2rem,4vw,3rem); font-weight:700; letter-spacing:-0.025em; color:var(--white);">
          From brief to live in 7 days.
        </h2>
      </div>

      <div class="process-grid" role="list">
        {process.map((step, i) => (
          <article class="process-step" role="listitem" aria-label={step.title}>
            <div class="process-step-day">{step.day}</div>
            <div class="process-step-icon" aria-hidden="true"><Fragment set:html={step.icon} /></div>
            <h3 class="process-step-title">{step.title}</h3>
            <p class="process-step-desc">{step.desc}</p>
            {i < process.length - 1 && <div class="process-connector" aria-hidden="true"></div>}
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── WHY FAZED ────────────────────────────────────────── -->
  <section class="lp-section">
    <div class="lp-container">
      <div class="lp-reveal" style="text-align:center; margin-bottom:3.5rem;">
        <div class="label" style="margin-bottom:1rem;">Why Choose Fazed Digital</div>
        <h2 style="font-family:var(--font-display); font-size:clamp(2rem,4vw,3rem); font-weight:700; letter-spacing:-0.025em; color:var(--white);">
          Speed meets quality.
        </h2>
      </div>

      <div class="why-grid">
        {[
          {
            icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
            title: '7x Faster',
            body: 'The industry average is 6–8 weeks. We deliver in 7 days — without cutting corners on quality.',
          },
          {
            icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
            title: 'Fixed Pricing',
            body: 'No hourly rates, no scope creep surprises. One price, one timeline, everything included.',
          },
          {
            icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
            title: 'SEO-Ready',
            body: 'Every page we build is optimised for search from day one — meta tags, schema, speed, and structure.',
          },
          {
            icon: `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>`,
            title: 'Mobile-First',
            body: 'Over 60% of web traffic is mobile. Every site we build looks and performs flawlessly on every device.',
          },
        ].map(item => (
          <div class="lp-reveal why-card">
            <div class="why-card-icon" aria-hidden="true"><Fragment set:html={item.icon} /></div>
            <h3 style="font-family:var(--font-display); font-size:1.25rem; font-weight:700; color:var(--white); letter-spacing:-0.02em; margin-bottom:0.6rem;">{item.title}</h3>
            <p style="color:var(--gray-400); font-size:0.9rem; line-height:1.6;">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── WORK SAMPLES ─────────────────────────────────────── -->
  <section class="lp-section" style="background:rgba(255,255,255,0.015); border-top:1px solid var(--border); border-bottom:1px solid var(--border);">
    <div class="lp-container">
      <div class="lp-reveal" style="text-align:center; margin-bottom:3rem;">
        <div class="label" style="margin-bottom:1rem;">Real Results</div>
        <h2 style="font-family:var(--font-display); font-size:clamp(2rem,4vw,3rem); font-weight:700; letter-spacing:-0.025em; color:var(--white);">
          Sites we've shipped.
        </h2>
      </div>

      <div class="work-grid">
        {[
          { img: '/images/work-aframing.jpg', title: 'A Framing Company', cat: 'Web Design + WordPress',  url: 'https://aframingcompany.com' },
          { img: '/images/work-cleen.jpg',    title: 'Cleen & Green',     cat: 'Brand Identity + WordPress', url: 'https://cleenandgreen.com' },
        ].map(w => (
          <a href={w.url} target="_blank" rel="noopener noreferrer" class="lp-reveal work-card" aria-label={`View ${w.title} live website`}>
            <div class="work-card-img-wrap">
              <img src={w.img} alt={`${w.title} website screenshot`} loading="lazy" decoding="async" width="600" height="400" />
              <div class="work-card-overlay">
                <span style="font-family:var(--font-display); font-size:1rem; font-weight:700; color:var(--accent);">View Live Site ↗</span>
              </div>
            </div>
            <div style="padding:1rem 0 0;">
              <div style="font-size:0.7rem; font-family:var(--font-mono); letter-spacing:0.12em; text-transform:uppercase; color:var(--gray-500); margin-bottom:0.3rem;">{w.cat}</div>
              <div style="font-family:var(--font-display); font-size:1.1rem; font-weight:700; color:var(--white);">{w.title}</div>
            </div>
          </a>
        ))}
      </div>

      <div class="lp-reveal" style="text-align:center; margin-top:2.5rem;">
        <a href="https://fazeddigital.com/work" style="color:var(--gray-400); font-size:0.9rem; text-decoration:none; border-bottom:1px solid var(--border);">
          See all our work →
        </a>
      </div>
    </div>
  </section>

  <!-- ─── FAQ ──────────────────────────────────────────────── -->
  <section class="lp-section">
    <div class="lp-container" style="max-width:740px;">
      <div class="lp-reveal" style="text-align:center; margin-bottom:3rem;">
        <div class="label" style="margin-bottom:1rem;">FAQ</div>
        <h2 style="font-family:var(--font-display); font-size:clamp(2rem,4vw,3rem); font-weight:700; letter-spacing:-0.025em; color:var(--white);">
          Common questions.
        </h2>
      </div>

      <div class="faq-list" itemscope itemtype="https://schema.org/FAQPage">
        {faqs.map((faq, i) => (
          <details class="lp-reveal faq-item" itemscope itemprop="mainEntity" itemtype="https://schema.org/Question">
            <summary itemprop="name">
              <span>{faq.q}</span>
              <span class="faq-chevron" aria-hidden="true">+</span>
            </summary>
            <div class="faq-answer" itemscope itemprop="acceptedAnswer" itemtype="https://schema.org/Answer">
              <p itemprop="text">{faq.a}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── CTA + FORM ───────────────────────────────────────── -->
  <section id="get-started" class="lp-section" style="background:rgba(201,255,87,0.03); border-top:1px solid rgba(201,255,87,0.1);">
    <div class="lp-container">

      <!-- Centered heading -->
      <div class="lp-reveal" style="text-align:center; max-width:640px; margin:0 auto 2.75rem;">
        <div class="label" style="color:var(--accent); margin-bottom:1rem;">Limited Spots Available</div>
        <h2 style="font-family:var(--font-display); font-size:clamp(2rem,4vw,3rem); font-weight:700; letter-spacing:-0.025em; color:var(--white); line-height:1.1; margin-bottom:1.1rem;">
          Ready to go live<br/>in 7 days?
        </h2>
        <p style="color:var(--gray-400); font-size:1rem; line-height:1.65; margin:0;">
          Tell us about your project and we'll get back to you within one business day
          with a confirmed start date. No commitment required.
        </p>
      </div>

      <!-- Trust pills row -->
      <div class="lp-reveal cta-pills">
        {[
          '✓ No contracts or lock-ins',
          '✓ Fixed price — no surprises',
          '✓ 7-day delivery or 20% off',
          '✓ Full ownership of your site',
        ].map(item => (
          <span class="cta-pill">{item}</span>
        ))}
      </div>

      <!-- Form — full width, capped at 780px -->
      <div class="lp-reveal" style="max-width:780px; margin:0 auto;">
        <LpForm client:visible />
      </div>

      <!-- Subtle email fallback -->
      <p class="lp-reveal" style="text-align:center; margin-top:1.75rem; font-size:0.82rem; color:var(--gray-600);">
        Prefer email?&nbsp;
        <a href="mailto:info@fazeddigital.com" style="color:var(--gray-400); text-decoration:underline; text-underline-offset:3px;">info@fazeddigital.com</a>
      </p>

    </div>
  </section>

  <!-- ─── FOOTER ───────────────────────────────────────────── -->
