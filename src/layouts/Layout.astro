---
import { ViewTransitions } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';
export interface Props {
  title?: string;
  description?: string;
  image?: string;
  page?: string;
  /** Pass page-specific JSON-LD schema objects (merged with site-level org schema) */
  schema?: object | object[];
}

const {
  title = 'Fazed Digital — Bold Creative Agency',
  description = 'Fazed Digital builds bold identities that speak your story — visually and verbally. Web design, brand identity, SEO marketing, and digital product design.',
  image = '/og-image.svg',
  page = 'home',
  schema,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://fazeddigital.com');
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta name="robots" content="index, follow" />
  <meta name="author" content="Fazed Digital" />
  <meta name="keywords" content="digital agency, web design, brand identity, SEO, Iligan City, Philippines, creative agency" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, 'https://fazeddigital.com')} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content={`${title} — Fazed Digital`} />
  <meta property="og:site_name" content="Fazed Digital" />
  <meta property="og:locale" content="en_PH" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@fazeddigital" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, 'https://fazeddigital.com')} />
  <meta name="twitter:image:alt" content={`${title} — Fazed Digital`} />

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />

  <!-- Fonts — preconnect first, then async load (non-blocking) -->
  <link rel="preconnect" href="https://api.fontshare.com" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <!-- Clash Display — loaded async so it never blocks first paint -->
  <link rel="preload" as="style"
    href="https://api.fontshare.com/v2/css?f[]=clash-display@700,600,500,400&display=swap" />
  <link rel="stylesheet" media="print" onload="this.media='all'"
    href="https://api.fontshare.com/v2/css?f[]=clash-display@700,600,500,400&display=swap" />

  <!-- Plus Jakarta Sans + Space Mono — async -->
  <link rel="preload" as="style"
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" />
  <link rel="stylesheet" media="print" onload="this.media='all'"
    href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" />

  <!-- Fallback for no-JS -->
  <noscript>
    <link rel="stylesheet" href="https://api.fontshare.com/v2/css?f[]=clash-display@700,600,500,400&display=swap" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" />
  </noscript>

  <!-- Google Analytics (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-FL744H1NJ7"></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){ dataLayer.push(arguments); }
    gtag('js', new Date());
    gtag('config', 'G-FL744H1NJ7');
  </script>

  <!-- View Transitions for SPA-like navigation -->
  <ViewTransitions />

  <!-- Schema.org — site-level Organisation -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Fazed Digital",
    "url": "https://fazeddigital.com",
    "logo": "https://fazeddigital.com/favicon.svg",
    "image": "https://fazeddigital.com/og-image.svg",
    "email": "info@fazeddigital.com",
    "telephone": "+639221234567",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Iligan City",
      "addressRegion": "Northern Mindanao",
      "addressCountry": "PH"
    },
    "geo": {
      "@type": "GeoCoordinates",
      "latitude": "8.2280",
      "longitude": "124.2452"
    },
    "description": "Fazed Digital is a bold creative agency in Iligan City, Philippines — building identities, websites, and digital experiences for ambitious brands.",
    "openingHours": "Mo-Fr 08:30-17:00",
    "priceRange": "$$",
    "areaServed": "Worldwide",
    "hasOfferCatalog": {
      "@type": "OfferCatalog",
      "name": "Digital Agency Services",
      "itemListElement": [
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Web Design & Development" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Brand Identity" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "SEO Marketing" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Product Design" } },
        { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Custom Systems" } }
      ]
    },
    "sameAs": [
      "https://fazeddigital.com",
      "https://www.facebook.com/fazeddigital",
      "https://www.instagram.com/fazeddigital"
    ]
  })} />

  {/* Page-specific schema (Article, BreadcrumbList, FAQPage, etc.) */}
  {schema && (
    Array.isArray(schema)
      ? schema.map((s, i) => <script type="application/ld+json" set:html={JSON.stringify(s)} key={i} />)
      : <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  )}
</head>

<body data-page={page}>
  <slot />
  <Analytics />
</body>
</html>

<style is:global>
  @import '../styles/global.css';

  /* Mobile nav & layout helpers */
  @media (max-width: 860px) {
    .grid-2, .two-col { grid-template-columns: 1fr !important; }
  }
  @media (max-width: 640px) {
    body { cursor: auto; }
    a, button, [role="button"] { cursor: auto; }
  }
</style>
