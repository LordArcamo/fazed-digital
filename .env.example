# HubSpot Form GUID
# Found in: HubSpot → Marketing → Forms → [your form] → edit URL
# URL format: app.hubspot.com/forms/244473168/{FORM_GUID}/edit
HUBSPOT_FORM_GUID=c119e15a-357c-4bfb-9264-a1fb3f1a3389

# Google reCAPTCHA v3 — get from console.cloud.google.com/recaptcha
# Site key is public (hardcoded in ContactSection.tsx)
# Secret key goes here (server-side verification only)
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
